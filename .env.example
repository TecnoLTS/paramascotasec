#############################################
# PARAMASCOTASEC - PLANTILLA DE VARIABLES
#############################################
#
# USO RECOMENDADO:
# - Produccion: usar este archivo como .env
# - Desarrollo: usar .env.development
#
# Comandos:
#   docker compose up -d --build
#   docker compose --env-file .env.development up -d --build
#
# PARAMETROS QUE PUEDEN VARIAR Y PARA QUE SIRVEN:
#
# APP_ENV
#   development -> levanta app-dev (npm run dev)
#   production  -> levanta app (npm run start)
APP_ENV=development

# COMPOSE_PROFILES
#   Perfil activo de docker compose.
#   Debe coincidir con APP_ENV.
COMPOSE_PROFILES=development

# PORT
#   Puerto publico del frontend en tu maquina.
PORT=3000

# API_FETCH_TIMEOUT_MS
#   Tiempo maximo de espera en ms para llamadas frontend -> backend.
API_FETCH_TIMEOUT_MS=15000

# NEXT_PUBLIC_BASE_URL
#   URL base publica del frontend (visible en navegador).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# NEXT_PUBLIC_BACKEND_URL
#   URL del backend usada por peticiones desde el navegador.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080/api

# BACKEND_URL_INTERNAL
#   URL interna para peticiones servidor a servidor desde el contenedor de Next.js.
#   Mantener nombre de servicio Docker para evitar dependencia de IP.
BACKEND_URL_INTERNAL=http://paramascotasec-backend-web/api

# BACKEND_SERVICE_TOKEN
#   Token de servicio para autenticar llamadas internas frontend -> backend.
#   Se genera en el backend con scripts/generate_service_token.php.
BACKEND_SERVICE_TOKEN=replace-with-service-token

# Ejemplo rapido para PRODUCCION:
# APP_ENV=production
# COMPOSE_PROFILES=production
# NEXT_PUBLIC_BASE_URL=https://paramascotasec.com
# NEXT_PUBLIC_BACKEND_URL=https://api.paramascotasec.com
