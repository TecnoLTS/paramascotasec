datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  legacyId    String?     @unique
  category    String      @map("categoria")
  name        String      @map("nombre")
  gender      String?     @map("genero")
  new         Boolean     @default(false) @map("nuevo")
  sale        Boolean     @default(false) @map("oferta")
  price       Decimal     @db.Decimal(10, 2) @map("precio")
  originPrice Decimal     @db.Decimal(10, 2) @map("precio_original")
  brand       String?     @map("marca")
  sold        Int         @default(0) @map("vendido")
  quantity    Int         @map("cantidad")
  description String      @map("descripcion")
  action      String?     @map("accion")
  slug        String      @unique
  images      Image[]     @relation("ProductImages")
  variations  Variation[]
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now()) @map("fecha_de_creacion")
  updatedAt   DateTime    @updatedAt @map("fecha_de_actualziacion")
}

model Variation {
  id         String  @id @default(cuid())
  color      String
  colorCode  String?
  colorImage String?
  image      String?
  product    Product @relation(fields: [productId], references: [id])
  productId  String
}

model Image {
  id        String   @id @default(cuid())
  url       String
  product   Product? @relation("ProductImages", fields: [productId], references: [id])
  productId String?
}

model Order {
  id        String      @id @default(cuid())
  user      User?       @relation(fields: [userId], references: [id])
  userId    String?
  status    String      @default("pending")
  total     Decimal     @db.Decimal(10, 2)
  items     OrderItem[]
  createdAt DateTime    @default(now())
}

model OrderItem {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
}
